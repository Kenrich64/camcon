PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=replace_with_strong_secret
ADMIN_CREATION_KEY=replace_with_admin_creation_key

# Frontend origins (comma-separated for production)
# Example:
# CLIENT_URL=https://your-app.vercel.app
# CLIENT_URLS=https://your-app.vercel.app,https://www.your-app.vercel.app
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000

# Cerebras AI
CEREBRAS_API_KEY=your_cerebras_api_key

# Neon/Production (preferred)
DATABASE_URL=postgresql://username:password@host.neon.tech/dbname?sslmode=require

# Local fallback (used when DATABASE_URL is not set)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=camcon_db
DB_PASSWORD=your_password
DB_PORT=5432